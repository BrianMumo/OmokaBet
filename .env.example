# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/omokabet

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRE=7d

# The Odds API
ODDS_API_KEY=your_odds_api_key_here

# M-Pesa (Safaricom Daraja API)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_B2C_SHORTCODE=your_b2c_shortcode
MPESA_B2C_INITIATOR=your_initiator_name
MPESA_B2C_PASSWORD=your_initiator_password
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
